# -*- coding: utf-8 -*-
"""
飞书连接器配置 - TalentAI Pro

使用方式:
1. 复制此文件为 config_feishu.py
2. 填入真实的飞书应用凭证
3. 在代码中导入使用:
   from config_feishu import FEISHU_APP_ID, FEISHU_APP_SECRET

创建飞书应用:
1. 访问 https://open.feishu.cn/app 登录
2. 点击 "创建企业自建应用"
3. 填写应用名称和描述
4. 获取 App ID (cli_xxx) 和 App Secret
5. 在 "权限管理" 中添加以下权限:
   - calendar:readonly (日历只读)
   - calendar:write (日历读写)
   - docx:readonly (文档只读)
   - docx:write (文档读写)
   - im:readonly (消息只读)
   - im:write (消息读写)
   - contact:readonly (联系人只读)
6. 点击 "版本管理与发布" 发布应用
7. 将应用机器人添加到群聊
"""

# ==============================================================================
# 方式1: 使用 App ID 和 App Secret（推荐）
# ==============================================================================

FEISHU_APP_ID = ""  # 例如: "cli_a1b2c3d4e5f6g7h8"
FEISHU_APP_SECRET = ""  # 飞书应用密钥

# ==============================================================================
# 方式2: 使用预定义的 Tenant Access Token
# 如果你已经有了tenant_access_token，可以直接使用这个
# ==============================================================================

# FEISHU_TENANT_TOKEN = ""  # 例如: "t-xxxxxxxxxxxxxxxxxx"

# ==============================================================================
# 日历配置
# ==============================================================================

# 使用主日历，或指定日历ID
# 日历ID可以在飞书日历中查看
FEISHU_CALENDAR_ID = "primary"

# ==============================================================================
# API配置
# ==============================================================================

# 默认搜索时间范围（天）
DEFAULT_SEARCH_DAYS = 30

# API重试次数
MAX_RETRIES = 3

# 重试延迟（秒）
RETRY_DELAY = 1

# ==============================================================================
# 测试配置
# ==============================================================================

# 测试用的chat_id（你的飞书群ID）
TEST_CHAT_ID = ""

# 测试用的用户邮箱
TEST_USER_EMAIL = ""
