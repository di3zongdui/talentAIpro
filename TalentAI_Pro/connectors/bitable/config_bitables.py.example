    # 候选人库 - 存储候选人信息
    "candidates": "",  # 例如: "tblxxxxxxxx"

    # 职位库 - 存储职位信息
    "jobs": "",  # 例如: "tblxxxxxxxx"

    # 招聘交易跟踪 - 存储招聘进度
    "deals": "",  # 例如: "tblxxxxxxxx"

    # 活动记录 - 存储跟进活动
    "activities": ""  # 例如: "tblxxxxxxxx"
}

