# -*- coding: utf-8 -*-
"""
飞书Bitable连接器配置 - TalentAI Pro

使用方式:
1. 复制此文件为 config_bitables.py
2. 填入真实的多维表格信息
3. 在代码中导入使用:
   from config_bitables import BITABLE_APP_ID, BITABLE_APP_SECRET, TABLES

创建Bitable并获取配置:
1. 在飞书中创建一个多维表格
2. 获取 App Token（从URL中获取）:
   URL格式: https://xxx.feishu.cn/base/xxxxxxxxx
   App Token: xxxxxxxxx（9位字母，通常以M开头）
3. 获取 Table ID:
   打开多维表格 → 点击右上角 "..." → "获取表格链接"
   或者在API中调用 /bitable/v1/apps/{app_token}/tables 获取
4. 获取字段名（中文）:
   打开多维表格 → 列标题就是字段名

创建飞书应用（如果还没有）:
1. 访问 https://open.feishu.cn/app
2. 创建企业自建应用
3. 添加权限:
   - bitable:app:readonly
   - bitable:app:write
4. 将应用添加到多维表格:
   打开多维表格 → 右上角 "分享" → "添加应用" → 搜索你的应用
"""

# ==============================================================================
# 飞书应用凭证
# ==============================================================================

BITABLE_APP_ID = ""  # 例如: "cli_a1b2c3d4e5f6g7h8"
BITABLE_APP_SECRET = ""  # 飞书应用密钥

# ==============================================================================
# 多维表格 App Token
# 从多维表格URL获取，格式: https://xxx.feishu.cn/base/MKLxxxxxxxx
# ==============================================================================

BITABLE_APP_TOKEN = ""  # 例如: "MKLxxxxxxxx"

# ==============================================================================
# 数据表配置
# ==============================================================================

