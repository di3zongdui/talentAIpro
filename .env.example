# TalentAI Pro Environment Configuration
# Copy this file to .env and fill in your values

# ============ Server Config ============
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
DEBUG=false

# ============ Database ============
DATABASE_URL=postgresql://talentai:talentai_secret@localhost:5432/talentai

# ============ Redis ============
REDIS_URL=redis://localhost:6379/0

# ============ API Keys ============
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_SECRET_KEY=your-secret-key-here

# ============ Feishu Config ============
FEISHU_APP_ID=your-feishu-app-id
FEISHU_APP_SECRET=your-feishu-app-secret
FEISHU_APP_TOKEN=your-feishu-app-token
FEISHU_CALENDAR_ID=your-calendar-id

# ============ Bitable Config ============
BITABLE_APP_ID=your-bitables-app-id
BITABLE_APP_SECRET=your-bitables-app-secret
BITABLE_CANDIDATES_TABLE_ID=your-candidates-table-id
BITABLE_JOBS_TABLE_ID=your-jobs-table-id
BITABLE_DEALS_TABLE_ID=your-deals-table-id

# ============ Mock Mode ============
# Set to true for development without real API credentials
MOCK_MODE=true

# ============ CORS ============
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ============ Rate Limiting ============
RATE_LIMIT_PER_MINUTE=60
